{
    "name": "wicle-sites-monorepo",
    "private": true,
    "scripts": {
        "dev": "turbo dev",
        "build": "turbo build",
        "lint": "turbo lint",
        "clean": "turbo clean",
        "test": "turbo test",
        "reset": "npm-run-all -s clean reset:turbo reset:node",
        "reset:turbo": "find . -type d -name .turbo -exec rm -rf {} +",
        "reset:node": "find . -type d -name node_modules -exec rm -rf {} +",
        "prepare-to-commit": "run-s build lint test clean"
    },
    "license": "MIT",
    "engines": {
        "node": ">=16.14"
    },
    "devDependencies": {
        "npm-run-all": "^4.1.5",
        "prettier": "^3.6.2",
        "prettier-plugin-astro": "^0.14.1",
        "turbo": "^2.5.4"
    },
    "packageManager": "pnpm@10.12.4"
}
