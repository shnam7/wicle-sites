{
    "name": "wicle-sites-monorepo",
    "private": true,
    "scripts": {
        "dev": "turbo run dev",
        "build": "turbo run build",
        "lint": "turbo run lint",
        "clean": "turbo run clean",
        "test": "turbo run test",
        "reset": "npm-run-all clean -p reset:*",
        "reset:turbo": "find . -type d -name .turbo -exec rm -rf {} +",
        "reset:astro": "find . -type d -name .astro -exec rm -rf {} +",
        "reset:node": "find . -type d -name node_modules -exec rm -rf {} +",
        "prepare-to-commit": "run-s clean lint build test clean"
    },
    "license": "MIT",
    "engines": {
        "node": ">=16.14"
    },
    "devDependencies": {
        "npm-run-all": "^4.1.5",
        "prettier": "^3.7.4",
        "prettier-plugin-astro": "^0.14.1",
        "turbo": "^2.7.3"
    },
    "packageManager": "pnpm@10.27.0"
}
