{
    "$schema": "https://turborepo.com/schema.json",
    "tasks": {
        "dev": {
            "cache": false,
            "persistent": true
        },
        "build": {
            "cache": true,
            "outputs": ["dist/**"],
            "dependsOn": ["^build"]
        },
        "lint": {
            "cache": false,
            "dependsOn": ["^lint"]
        },
        "test": {
            "outputs": ["coverage/**"],
            "dependsOn": ["^test"]
        },
        "clean": {
            "cache": false,
            "dependsOn": ["^clean"]
        }
    }
}
