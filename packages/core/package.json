{
    "name": "wicle-sites",
    "version": "3.0.0",
    "type": "module",
    "main": "./dist/index.cjs",
    "module": "./dist/index.mjs",
    "types": "./dist/index.d.ts",
    "exports": {
        "require": "./dist/index.cjs",
        "import": "./dist/index.mjs"
    },
    "files": [
        "dist/**",
        "wicle/**",
        "!**/*.map"
    ],
    "scripts": {
        "dev": "run-s build watch",
        "dev:test": "vitest watch --coverage --coverage.include=scripts",
        "build": "run-p build:**",
        "build:ts": "tsdown scripts/index.ts --format cjs,esm --dts",
        "build:ts:types": "tsc --noEmit ",
        "lint": "run-p lint:*",
        "lint:ts": "xo",
        "lint:scss": "stylelint --config stylelint.config.js wicle/**/*.scss",
        "test": "vitest run --coverage --coverage.include=scripts",
        "watch": "run-p watch:*",
        "watch:ts": "chokidar 'scripts/**/*.ts' -c 'run-p \"build:ts --no-clean\" build:ts:types'",
        "__watch:ts": "run-p 'build:ts --no-clean --watch' 'build:ts:types'",
        "watch:scss": "chokidar 'wicle/**/*.scss' -c 'pnpm run lint:scss'",
        "clean": "rimraf ./dist ./coverage",
        "rebuild": "run-s clean build",
        "prepare-to-commit": "run-s clean lint test build clean",
        "npm-dry-run": "npm publish --dry-run"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/shnam7/wicle-sites.git",
        "directory": "packages/core"
    },
    "homepage": "https://github.com/shnam7/wicle-sites#readme",
    "bugs": {
        "url": "https://github.com/shnam7/wicle-sites/issues"
    },
    "author": {
        "name": "Robin Nam",
        "email": "shnam7@gmail.com"
    },
    "license": "MIT",
    "publishConfig": {
        "access": "public"
    },
    "keywords": [
        "web",
        "component",
        "library",
        "scss",
        "scss",
        "typescript"
    ],
    "devDependencies": {
        "@changesets/cli": "^2.29.8",
        "@types/node": "^25.0.3",
        "@vitest/coverage-v8": "^4.0.16",
        "@wicle/tsconfig": "github:shnam7/wicle-tsconfig",
        "changesets": "^1.0.2",
        "chokidar-cli": "^3.0.0",
        "happy-dom": "^20.1.0",
        "lightningcss": "^1.30.2",
        "npm-run-all2": "^8.0.4",
        "prettier": "^3.7.4",
        "rimraf": "^6.1.2",
        "sass": "^1.97.2",
        "sass-true": "^10.1.0",
        "sass-wdk": "file://~/dev/public/sass-wdk",
        "stylelint": "^16.26.1",
        "stylelint-config-standard-scss": "^16.0.0",
        "stylelint-scss": "^6.14.0",
        "tsdown": "^0.18.4",
        "typescript": "^5.9.3",
        "vitest": "^4.0.16",
        "xo": "^1.2.3"
    },
    "packageManager": "pnpm@10.27.0"
}
