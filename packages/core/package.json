{
    "name": "wicle-sites",
    "version": "0.1.0",
    "type": "module",
    "main": "./dist/index.cjs",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        "require": "./dist/index.cjs",
        "import": "./dist/index.js"
    },
    "files": [
        "dist/**",
        "wicle/**",
        "!**/*.map"
    ],
    "scripts": {
        "dev": "run-s build watch",
        "build": "run-p build:ts build:scss",
        "build:ts": "tsdown scripts/index.ts --format cjs,esm --dts",
        "build:scss": "pnpm run lint:scss",
        "lint": "run-s lint:ts lint:scss",
        "lint:ts": "tsc --noEmit && xo",
        "lint:scss": "stylelint --config stylelint.config.js wicle/**/*.scss",
        "test": "vitest run --coverage --coverage.include=src",
        "test:watch": "vitest watch --coverage --coverage.include=src",
        "watch": "run-p watch:ts watch:scss",
        "watch:ts": "pnpm run build:ts --watch",
        "watch:scss": "chokidar 'wicle/**/*.scss' -c 'pnpm run lint:scss'",
        "clean": "rimraf ./dist ./coverage",
        "rebuild": "run-s clean build",
        "prepare-to-commit": "run-s clean lint test build clean",
        "npm-dry-run": "npm publish --dry-run"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/shnam7/wicle-mutex"
    },
    "homepage": "https://github.com/shnam7/wicle-mutex#readme",
    "bugs": {
        "url": "https://github.com/shnam7/wicle-mutex/issues"
    },
    "author": {
        "name": "Robin Nam",
        "email": "shnam7@gmail.com"
    },
    "license": "MIT",
    "publishConfig": {
        "access": "public"
    },
    "keywords": [
        "web",
        "component",
        "library",
        "scss",
        "scss",
        "typescript"
    ],
    "devDependencies": {
        "@changesets/cli": "^2.29.5",
        "@types/jquery": "^3.5.32",
        "@types/node": "^24.0.8",
        "@vitest/coverage-v8": "^3.2.4",
        "@wicle/tsconfig": "github:shnam7/wicle-tsconfig",
        "changesets": "^1.0.2",
        "chokidar-cli": "^3.0.0",
        "jquery": "^3.7.1",
        "lightningcss": "^1.30.1",
        "npm-run-all": "^4.1.5",
        "rimraf": "^6.0.1",
        "sass": "^1.89.2",
        "sass-true": "^9.0.0",
        "sass-wdk": "file://~/dev/public/sass-wdk",
        "stylelint": "^16.21.0",
        "stylelint-config-standard-scss": "^15.0.1",
        "stylelint-scss": "^6.12.1",
        "tsdown": "^0.12.9",
        "typescript": "^5.8.3",
        "vitest": "^3.2.4",
        "xo": "^1.1.1"
    },
    "packageManager": "pnpm@10.12.4"
}
