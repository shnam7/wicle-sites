{
    "name": "wicle-sites",
    "version": "3.0.0",
    "type": "module",
    "main": "./dist/index.cjs",
    "module": "./dist/index.mjs",
    "types": "./dist/index.d.cts",
    "sideEffects": false,
    "exports": {
        ".": {
            "import": {
                "types": "./dist/index.d.mts",
                "default": "./dist/index.mjs"
            },
            "require": {
                "types": "./dist/index.d.cts",
                "default": "./dist/index.cjs"
            }
        }
    },
    "files": [
        "dist/**",
        "wicle/**",
        "!**/*.map"
    ],
    "scripts": {
        "dev": "run-s build watch",
        "dev:test": "vitest watch --coverage --coverage.include=scripts",
        "build": "run-p build:**",
        "build:ts": "tsdown scripts/index.ts --format cjs,esm --dts",
        "build:ts:types": "tsc --noEmit ",
        "lint": "run-p lint:*",
        "lint:ts": "xo",
        "lint:scss": "stylelint --config stylelint.config.js wicle/**/*.scss",
        "test": "vitest run --coverage --coverage.include=scripts",
        "watch": "run-p watch:*",
        "watch:ts": "chokidar 'scripts/**/*.ts' -c 'run-p \"build:ts --no-clean\" build:ts:types'",
        "__watch:ts": "run-p 'build:ts --no-clean --watch' 'build:ts:types'",
        "watch:scss": "chokidar 'wicle/**/*.scss' -c 'pnpm run lint:scss'",
        "clean": "rimraf ./dist ./coverage",
        "rebuild": "run-s clean build",
        "prepare-to-commit": "run-s clean lint test build clean",
        "npm-dry-run": "npm publish --dry-run"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/shnam7/wicle-sites.git",
        "directory": "packages/core"
    },
    "homepage": "https://github.com/shnam7/wicle-sites#readme",
    "bugs": {
        "url": "https://github.com/shnam7/wicle-sites/issues"
    },
    "author": {
        "name": "Robin Nam",
        "email": "shnam7@gmail.com"
    },
    "license": "MIT",
    "publishConfig": {
        "access": "public"
    },
    "keywords": [
        "web",
        "component",
        "library",
        "scss",
        "typescript"
    ],
    "devDependencies": {
        "@changesets/cli": "^2.31.0",
        "@types/node": "^26.0.1",
        "@vitest/coverage-v8": "^4.1.9",
        "@wicle/tsconfig": "github:shnam7/wicle-tsconfig",
        "changesets": "^1.0.2",
        "chokidar-cli": "^3.0.0",
        "happy-dom": "^20.10.6",
        "lightningcss": "^1.32.0",
        "npm-run-all2": "^9.0.2",
        "prettier": "^3.9.3",
        "rimraf": "^6.1.3",
        "sass": "^1.101.0",
        "sass-true": "^10.1.0",
        "sass-wdk": "^1.2.0",
        "stylelint": "^17.14.0",
        "stylelint-config-standard": "^40.0.0",
        "stylelint-config-standard-scss": "^17.0.0",
        "stylelint-scss": "^7.2.0",
        "tsdown": "^0.22.3",
        "typescript": "^6.0.3",
        "vitest": "^4.1.9",
        "xo": "^3.0.2"
    },
    "packageManager": "pnpm@11.9.0"
}
