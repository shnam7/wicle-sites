---
import Head from '../components/Head.astro'
import SiteBackground from '../components/SiteBackground.astro'
import SiteHeader from '../components/SiteHeader.astro'
import SiteBanner from '../components/SiteBanner.astro'
import SiteFooter from '../components/SiteFooter.astro'
import SiteOffcanvas from '../components/SiteOffcanvas.astro'
import Sidebar from '../components/Sidebar.astro'
import '../styles/main.scss'

const {title, frontpage, bodyClass} = Astro.props.frontmatter || Astro.props
---

<html lang='en'>
    <head><Head title={title} /></head>
    <body class={bodyClass}>
        <SiteBackground />
        <div class='l-site-container'>
            <header class='l-site-header'><SiteHeader /></header>
            {frontpage && <SiteBanner />}
            <div class='l-site-content'>
                <div class='l-page'>
                    <div class='l-content'>
                        <h1>{title}</h1>
                        <slot />
                    </div>
                    <div class='l-sidebar'><Sidebar /></div>
                </div>
            </div>
            <footer class='l-site-footer'><SiteFooter /></footer>
        </div>
        <!-- l-site-container  -->
        <SiteOffcanvas />
    </body>
</html>

<style>
    .l-page {
        padding-bottom: 3.5rem;
    }
</style>

<script>
    import {Parallax} from 'wicle-sites'

    const body = document.querySelector<HTMLElement>('body')!

    // --- Init parallax on banner media
    const parallaxControl = new Parallax.Container(window, 0.7)
    const surface = body.querySelector<HTMLElement>('#parallax-surface-1')!
    parallaxControl.addSurface(new Parallax.Surface(surface, 0.5))

    // --- Fix banner and parallax positions and sizes
    window.addEventListener('resize', e => {
        const header = body.querySelector<HTMLElement>('.l-site-header')
        const banner = body.querySelector<HTMLElement>('.l-site-banner')
        const background = body.querySelector<HTMLElement>('.l-site-background')!
        background.style.height = `${(header?.offsetHeight ?? 0) + (banner?.offsetHeight ?? 0)}px`
        surface.style.top = (header?.offsetHeight ?? 0) + 'px'

        // fix l-site-background height
        if (banner?.children.length === 0) banner.style.display = 'none'
    })

    // --- Trigger resize to initiate elements resizing and repositioning
    window.dispatchEvent(new Event('resize'))
</script>
