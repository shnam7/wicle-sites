---
import DefaultLayout from '../../layouts/DefaultLayout.astro'
import NavExample1 from '../../components/demo/NavExample1.astro'
import NavExample2 from '../../components/demo/NavExample2.astro'
import NavExampleIcons from '../../components/demo/NavExampleIcons.astro'

const title = 'Nav'
const clsSingle = 'w-nav'
const clsSingleHorizontal = 'w-nav wo-horizontal'
const clsSingleSeparators = 'w-nav wo-horizontal wo-separators'
const clsAccordion = 'w-nav wo-accordion'
const clsDropdown = 'w-nav wo-dropdown'
const clsHorizontalDropdown = 'w-nav wo-horizontal wo-dropdown wo-pointer wo-separators'
const clsHorizontalInvert = 'w-nav wo-horizontal wo-dropdown wo-pointer wo-separators wo-invert'
const clsDefault = 'w-nav wo-default'

const cases = [
    {
        title: 'Single-level vertical menu',
        cls: 'w-nav',
    },
    {
        title: 'Single-level horizontal menu',
        cls: 'w-nav wo-horizontal',
    },
    {
        title: 'Single-level custom colored horizontal nav',
        cls: 'w-nav wo-horizontal',
        clsPanel: 'wo-primary custom',
    },
    {
        title: 'Single-level horizontal menu with separators',
        cls: 'w-nav wo-horizontal wo-separators',
    },
    {
        title: 'Accordion menu',
        cls: 'w-nav wo-accordion',
    },
    {
        title: 'Dropdown menu',
        cls: 'w-nav wo-dropdown',
    },
    {
        title: 'Horizontal Dropdown menu',
        cls: 'w-nav wo-horizontal wo-dropdown wo-pointer wo-separators',
    },
    {
        title: 'Horizontal Dropdown menu - Inverted',
        cls: 'w-nav wo-horizontal wo-dropdown wo-pointer wo-separators wo-invert',
        clsPanel: 'custom inverted',
    },
    {
        title: 'Default menu',
        cls: 'w-nav wo-default',
    },
]

// bodyClass: demo-nav
---

<DefaultLayout title={title} bodyClass='demo-nav'>
    {
        cases.map(item => (
            <>
                <div class='w-divider wo-thick' />
                <div class={`demo-panel w-panel ${item.clsPanel || ''}`}>
                    <h3>{item.title}</h3>
                    <p class='caption'>class='{item.cls}'</p>
                    <NavExample1 cls={item.cls} />
                    <NavExampleIcons cls={item.cls} />
                </div>
            </>
        ))
    }

    <div class='bottom-padding'></div>
</DefaultLayout>

<style lang='scss'>
    @use 'wdk/color';
    .caption {
        color: brown;
        text-decoration: underline;
    }

    .bottom-padding {
        padding-bottom: 5rem;
    }
</style>

<style is:global lang='scss'>
    @use 'wdk/color';
    .w-panel.custom {
        .w-nav > li > a {
            color: #ccc;
        }
        &.inverted {
            .caption {
                color: burlywood;
            }
            color: #ccc;
            background: rgba(black, 0.85);
        }
    }
</style>
