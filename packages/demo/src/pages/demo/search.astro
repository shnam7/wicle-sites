---
import DefaultLayout from '../../layouts/DefaultLayout.astro'
import SearchDemo from '../../components/demo/SearchDemo.astro'

const title = 'Search'
const bodyClass = 'demo-search'
const aligns = ['left', 'center', 'right']
---

<DefaultLayout title={title} bodyClass={bodyClass}>
    {

    aligns.map(align => (
        <div class="w-divider wo-thick"></div>
        <h2 class="title">Align: {align}</h2>
        <SearchDemo align={align} />
    ))}
</DefaultLayout>

<style lang='scss'>
.title {
    text-align: center;
    color: indigo;
    margin: 1rem 0;
}
</style>
