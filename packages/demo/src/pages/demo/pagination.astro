---
import DefaultLayout from '../../layouts/DefaultLayout.astro'

const title = 'Pagination'
const bodyClass = 'demo-pagination'
const demoCases = [{cls: 'w-pagination'}, {cls: 'w-pagination wo-circle'}]
// bodyClass: demo-pagination
---

<DefaultLayout title={title} bodyClass={bodyClass}>
    {
        demoCases.map(demoCase => (
            <div class='demo-pagination-panel'>
                <nav class={demoCase.cls}>
                    <div class='page-links'>
                        <a class='prev page-numbers' href='#' />
                        <a class='page-numbers' href='#'>
                            1
                        </a>
                        <a class='page-numbers' href='#'>
                            2
                        </a>
                        <a class='page-numbers current' href='#'>
                            3
                        </a>
                        <a class='page-numbers' href='#'>
                            4
                        </a>
                        <a class='page-numbers' href='#'>
                            5
                        </a>
                        <a class='next page-numbers' href='#' />
                    </div>
                </nav>
            </div>
        ))
    }
</DefaultLayout>

<style lang='scss'>
    .demo-pagination-panel {
        margin: 1.5rem 1rem;
    }
</style>
