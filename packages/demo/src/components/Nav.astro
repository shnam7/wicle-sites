---
import NavItem from './NavItem.astro'

const {title, url, sub} = Astro.props
---

<NavItem title={title} url={url} sub={sub} />
{
    sub?.length > 0 && (
        <ul>
            {sub.map((item: any) => (
                <NavItem title={item.title} url={item.url} sub={item.sub} />
            ))}
        </ul>
    )
}
