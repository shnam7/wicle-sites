---
import site from '../data/site.json'
import path from 'path'
const baseUrl = process.env.NODE_ENV === 'production' ? site.baseUrl : '/'

const demoNames = [
    'colors',
    'typography',
    'buttons',
    'nav',
    'dividers',
    'panels',
    'search',
    'images',
    'parallax',
    'pagination',
    'offcanvas',
    'media-query',
    'snippets',
]
---

<h3>Contents</h3>

<p>Version {site.version}</p>
<p>---</p>

<ul>
    <li><a href={path.join(baseUrl ?? '', 'getting-started')}>Getting Started</a></li>
    <li><a href='#demo'>Demo</a></li>
    <ul>
        {
            demoNames.map(name => (
                <li>
                    <a href={path.join(baseUrl ?? '', 'demo/', name)}>
                        {name.charAt(0).toUpperCase() + name.slice(1)}
                    </a>
                </li>
            ))
        }
    </ul>
</ul>
