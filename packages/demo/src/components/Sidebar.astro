---
import {getVersion} from 'wicle-sites'

const base = import.meta.env.BASE_URL // '/wicle-sites/' in prod, '/' in dev

const demoNames = [
    'colors',
    'typography',
    'buttons',
    'nav',
    'dividers',
    'panels',
    'search',
    'images',
    'parallax',
    'pagination',
    'offcanvas',
    'media-query',
    'snippets',
]
---

<h3>Contents</h3>
<div class='w-divider wo-thick'></div>

<ul>
    <li><a href={`${base}getting-started`}>Getting Started</a></li>
    <li><a href='#demo'>Demo</a></li>
    <ul>
        {
            demoNames.map(name => (
                <li>
                    <a href={`${base}demo/${name}`}>
                        {name.charAt(0).toUpperCase() + name.slice(1)}
                    </a>
                </li>
            ))
        }
    </ul>
</ul>
